@{
    ViewData["Title"] = "Главная";
}

<!-- Hero Section -->
<div class="hero-section text-center">
    <div class="container">
        <div class="welcome-icon">🏨</div>
        <span class="feature-badge">Управление гостиничным комплексом</span>
        <h1 class="hero-title">Добро пожаловать в Hotel Complex</h1>
        <p class="hero-subtitle">Современная система автоматизации для вашего отеля</p>
    </div>
</div>

<!-- Statistics Cards -->
<div class="container">
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-custom">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @ViewBag.ErrorMessage
        </div>
    }

    <div class="row g-4">
        <!-- Rooms Card -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="card-header">
                    <i class="bi bi-door-open me-2"></i>Номера
                </div>
                <div class="card-body text-center">
                    <div class="stat-number">@ViewBag.RoomsCount</div>
                    <div class="stat-label">Всего номеров</div>
                    <a href="@Url.Action("Index", "Rooms")" class="stat-link">
                        Подробнее <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Available Rooms Card -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="card-header">
                    <i class="bi bi-check-circle me-2"></i>Свободные
                </div>
                <div class="card-body text-center">
                    <div class="stat-number">@ViewBag.AvailableRooms</div>
                    <div class="stat-label">Доступно для бронирования</div>
                    <a href="@Url.Action("Available", "Rooms")" class="stat-link">
                        Подробнее <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Guests Card -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="card-header">
                    <i class="bi bi-people me-2"></i>Гости
                </div>
                <div class="card-body text-center">
                    <div class="stat-number">@ViewBag.GuestsCount</div>
                    <div class="stat-label">Зарегистрировано</div>
                    <a href="#" class="stat-link">
                        Подробнее <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Bookings Card -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="card-header">
                    <i class="bi bi-calendar-check me-2"></i>Бронирования
                </div>
                <div class="card-body text-center">
                    <div class="stat-number">@ViewBag.BookingsCount</div>
                    <div class="stat-label">Активных броней</div>
                    <a href="#" class="stat-link">
                        Подробнее <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions-card">
        <h3 class="quick-actions-title">
            <i class="bi bi-lightning-charge-fill me-2"></i>Быстрые действия
        </h3>

        <div class="text-center">
            <a href="@Url.Action("Index", "Rooms")" class="action-btn">
                <i class="bi bi-door-open"></i> Управление номерами
            </a>

            <a href="#" class="action-btn">
                <i class="bi bi-calendar-plus"></i> Новое бронирование
            </a>

            <a href="#" class="action-btn">
                <i class="bi bi-person-plus"></i> Регистрация гостя
            </a>

            <a href="#" class="action-btn action-btn-outline">
                <i class="bi bi-file-text"></i> Отчеты
            </a>

            <a href="#" class="action-btn action-btn-outline">
                <i class="bi bi-graph-up"></i> Статистика
            </a>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row mt-5">
        <div class="col-12">
            <h3 class="section-title text-center mb-4">Возможности системы</h3>
        </div>

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <div class="card-body">
                    <i class="bi bi-building feature-icon"></i>
                    <h5 class="feature-title">Управление номерами</h5>
                    <p class="feature-text">Полный контроль над статусами и загрузкой номерного фонда</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <div class="card-body">
                    <i class="bi bi-credit-card feature-icon"></i>
                    <h5 class="feature-title">Финансовый учет</h5>
                    <p class="feature-text">Автоматическое формирование счетов и учет платежей</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="feature-card">
                <div class="card-body">
                    <i class="bi bi-cup-hot feature-icon"></i>
                    <h5 class="feature-title">Дополнительные услуги</h5>
                    <p class="feature-text">Заказ и учет всех услуг для гостей</p>
                </div>
            </div>
        </div>
    </div>
</div>