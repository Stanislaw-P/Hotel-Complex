<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Гостиничный комплекс</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom Theme CSS -->
    <link rel="stylesheet" href="~/css/hotel-theme.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-building me-2"></i>Гостиничный комплекс
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Главная
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Rooms" asp-action="Index">
                                <i class="bi bi-door-open me-1"></i>Номера
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Guests" asp-action="Index">
                                <i class="bi bi-people me-1"></i>Гости
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Bookings" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>Бронирования
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-column">
                    <h4 class="footer-title">
                        <i class="bi bi-building me-2"></i>О нас
                    </h4>
                    <p style="color: var(--secondary-sand); opacity: 0.9; line-height: 1.6;">
                        Горный гостиничный комплекс с супер красивым видом на горы.
                        Комфорт и уют для наших гостей.
                    </p>
                    <div class="social-links">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-telegram"></i></a>
                        <a href="#"><i class="bi bi-whatsapp"></i></a>
                    </div>
                </div>

                <div class="footer-column">
                    <h4 class="footer-title">
                        <i class="bi bi-link me-2"></i>Быстрые ссылки
                    </h4>
                    <ul class="footer-links">
                        <li><a href="@Url.Action("Index", "Rooms")"><i class="bi bi-chevron-right"></i> Номера</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i> Бронирование</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i> Услуги</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i> Контакты</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i> Отели</a></li>
                    </ul>
                </div>

                <div class="footer-column">
                    <h4 class="footer-title">
                        <i class="bi bi-clock me-2"></i>Режим работы
                    </h4>
                    <div class="footer-contact">
                        <i class="bi bi-calendar-check"></i>
                        <span>Ежедневно: 24/7</span>
                    </div>
                    <div class="footer-contact">
                        <i class="bi bi-clock"></i>
                        <span>Круглосуточная регистрация</span>
                    </div>
                </div>

                <div class="footer-column">
                    <h4 class="footer-title">
                        <i class="bi bi-geo-alt me-2"></i>Контакты
                    </h4>
                    <div class="footer-contact">
                        <i class="bi bi-geo-alt"></i>
                        <span>Дигорское ущелье, 42</span>
                    </div>
                    <div class="footer-contact">
                        <i class="bi bi-telephone"></i>
                        <span>+7 (999) 123-45-67</span>
                    </div>
                    <div class="footer-contact">
                        <i class="bi bi-envelope"></i>
                        <span>info@hotelcomplex.ru</span>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="row">
                    <div class="col-md-6 text-md-start">
                        <i class="bi bi-building me-2"></i>
                        &copy; @DateTime.Now.Year - Гостиничный комплекс. Все права защищены.
                    </div>
                    <div class="col-md-6 text-md-end">
                        <i class="bi bi-star-fill me-1" style="color: var(--secondary-sand);"></i>
                        <span>Лучше не найдете</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>